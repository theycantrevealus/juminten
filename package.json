{
  "scripts": {
    "docs": "typedoc --entryPoints apps --out docs --tsconfig ./tsconfig.json",
    "prepack": "npm run build",
    "test:unit": "jest --detectOpenHandles --forceExit --verbose --runInBand --coverage --no-cache --passWithNoTests --config ./jest.unit.json",
    "test:unit:integration:core": "jest --detectOpenHandles --forceExit --verbose --runInBand --coverage --no-cache --passWithNoTests --config ./jest.unit.integration.core.json",
    "test:e2e": "jest --detectOpenHandles --forceExit --verbose --runInBand --coverage --no-cache --passWithNoTests --config ./jest.e2e.json",
    "prepare": "husky",
    "release": "semantic-release",
    "start:webpack:gateway_main": "nest build gateway_main --webpack --webpackPath ./webpack.config.js --watch",
    "start:webpack:consumer_redeem": "nest build consumer_redeem --webpack --webpackPath ./webpack.config.js --watch"
  },
